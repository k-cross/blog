		"katex": "^0.16.35",
		"lodash": "^4.17.23",
		"mdsvex": "^0.12.6",
		"mermaid": "^11.12.3",
		"polished": "^4.3.1",
		"prismjs": "^1.30.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-katex": "4.0.0",
		"rehype-slug": "^6.0.0"
	}
